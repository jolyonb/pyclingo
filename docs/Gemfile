source "https://rubygems.org"

# Local preview of the GitHub Pages site:
#   bundle install
#   bundle exec jekyll serve
# GitHub's own Pages builder ignores this file. (It uses the github-pages
# gem — Jekyll 3.9 — which no longer runs on modern Ruby, so we preview
# with Jekyll 4 plus the same plugins GitHub enables by default.)
gem "jekyll", "~> 4.4"
gem "jekyll-theme-primer"
gem "jekyll-seo-tag"
gem "jekyll-github-metadata"
gem "jekyll-optional-front-matter"
gem "jekyll-readme-index"
gem "jekyll-relative-links"
gem "jekyll-default-layout"
gem "webrick"
